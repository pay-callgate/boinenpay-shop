# =============================================================================
# CallLink ShoppingMaster — 환경 변수 예시 (커밋 가능)
#
# 사용법:
#   1) 이 파일을 복사:  copy .env.local.example .env.local  (PowerShell: Copy-Item)
#   2) .env.local 안의 CHANGE_ME·빈 값을 실제 값으로 채움 (비밀은 Git에 올리지 마세요)
#
# 앞으로 템플릿·변수 설명 변경은 이 파일(.env.local.example)만 수정합니다.
# =============================================================================

# --- 앱 공개 URL ---
# 로컬: http://localhost:3000
# 배포·뉴런 var_ret: 반드시 뉴런이 호출 가능한 HTTPS (예: Vercel 프로덕션, Ngrok)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- NextAuth (필수) ---
# NEXTAUTH_URL 은 NEXT_PUBLIC_APP_URL 과 보통 동일 호스트 (로컬 3000 / 배포 도메인)
NEXTAUTH_URL=http://localhost:3000
# 생성 예: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET

# --- Supabase (필수) ---
NEXT_PUBLIC_SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SERVICE_ROLE_KEY

# --- OAuth: 카카오·네이버 (미설용 시 빈 값 가능) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- ViewPay / 보인페이 ---
# 운영 결제 테스트 시 PG사가 준 실연동 URL 로 변경 (스테이징 URL이면 실카드 승인/콜백이 어긋날 수 있음)
VIEWPAY_API_BASE_URL=https://stgvl.boinenpay.com
VIEWPAY_MERCHANT_ID=
VIEWPAY_CHANNEL_ID=
VIEWPAY_APP_ID=
VIEWPAY_APP_KEY=
VIEWPAY_WEBHOOK_URL=
# VIEWPAY_SIMULATE_STARTPAY_ERROR=9097

# --- 비회원 결제 HMAC (선택, 없으면 NEXTAUTH_SECRET 폴백) ---
# GUEST_CHECKOUT_HMAC_SECRET=

# --- MsgAgent 알림톡 (lib/msgagent-kakao.ts) ---
MSGAGENT_USER_ID=
MSGAGENT_CALLBACK=
MSGAGENT_SENDER_KEY=
MSGAGENT_TEMPLATE_CODE=
MSGAGENT_BASE=https://api2.msgagent.com
# MSGAGENT_FAILED_TYPE=LMS
# MSGAGENT_FAILED_SUBJECT=
# MSGAGENT_RESELLER_CODE=
# MSGAGENT_BTN_TYPES=
# MSGAGENT_BTN_TXTS=
# MSGAGENT_BTN_URLS1=
# MSGAGENT_BTN_URLS2=

# --- 알림톡 링크용 공개 origin (선택) ---
# ALIMTALK_PUBLIC_ORIGIN=

# --- 이메일 SMTP / SOLAPI 문자 (선택) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_NAME=CallLink Shopping
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_FROM_NUMBER=

# --- 어드민 유휴 로그아웃 (분) ---
# NEXT_PUBLIC_ADMIN_IDLE_TIMEOUT_MIN=30

# --- 뉴런 Po-return 실패 안내 전화 (선택, NEXT_PUBLIC_) ---
# NEXT_PUBLIC_WOORIBUGO_CS_TEL=02-0000-0000

# --- 체크아웃 테스트 기본값 (운영 전 0 또는 삭제) ---
# NEXT_PUBLIC_ENABLE_CHECKOUT_TEST_DEFAULTS=0

# --- CallCloud / 070 (선택) ---
# BROWSERLESS_WS_ENDPOINT=
# CALLCLOUD_HEADLESS=true
# CALLCLOUD_ID=
# CALLCLOUD_PWD=
# CALLCLOUD_CHROME_EXECUTABLE=
# CALLCLOUD_KEEP_BROWSER_OPEN=false

# --- MsgAgent 로컬 로그 (선택) ---
# AGENT_LOG_DIR=
# LOG_FULL_SENDER_KEY=

# =============================================================================
# 뉴런(Newrun) / 협회 — 운영 실발주 테스트 전 필수 점검
# =============================================================================
# [Vercel(또는 운영 호스트) 서버 환경 변수에 동일 키로 설정]
#
# 1) NEXT_PUBLIC_APP_URL / NEXTAUTH_URL = 실제 쇼핑몰 HTTPS (예: https://www.calllinkshop.com)
# 2) 결제 완료 후 자동 발주: NEWRUN_ENABLED=true 이고 NEWRUN_MOCK=false
# 3) rw_returnurl: 뉴런이 브라우저로 열 수 있는 공개 HTTPS. 예:
#    NEWRUN_RW_RETURNURL=https://www.calllinkshop.com/wooribugo/wooribu/newrun/po-return
# 4) rw_rosewebid: 코드는 process.env.NEWRUN_ROSEWEB_ID 만 폼에 넣음.
#    우리부고와 받은 로그인 ID를 반드시 NEWRUN_ROSEWEB_ID에 넣을 것(비어 있으면 발주 검증 실패).
# 5) 상품 DB: products.newrun_default_product_draft 에 협의된 rw_menucode (JSON) — 스크립트 scripts/newrun-prod-test-readiness.sql 참고
# 6) 본부발주(head) 경로: 수주화원(rw_sujuid) 없이 발주 시도하지만 rw_menucode 는 draft 필수
#
# 수주화원·상품 검색 URL용(어드민 협회 검색 등)
NEWRUN_ASSOC_BASE_URL=http://www.kot45.com
NEWRUN_ASSOC_INTRANET_ID=CHANGE_ME_INTRANET_ID

NEWRUN_ROSEWEB_ID=CHANGE_ME_SAME_AS_WOORIBUGO_ROSEWEB_LOGIN_ID
NEWRUN_ROSEWEB_PW=CHANGE_ME_ROSEWEB_PASSWORD
# rw_assoc — 비어 있으면 submit 시 NEWRUN_ASSOC_INTRANET_ID로 폴백
NEWRUN_ASSOC_CODE=
NEWRUN_RW_RETURNURL=https://CHANGE_ME_DOMAIN/wooribugo/wooribu/newrun/po-return
# NEWRUN_RW_ASSOCID=

# NEWRUN_DEFAULT_RW_SENDPEOPLE=발주 시 리본 기본 보내는 사람(선택, 길이 제한 있음)
# NEWRUN_DEFAULT_RW_METHOD=1
# NEWRUN_INTRANET_POST_URL=http://ext2intra.roseweb.co.kr/intranet_post.html

# --- 스위치 ---
# 로컬/일반: Mock·비활성 권장. 운영에서 우리부고 실발주 테스트 시에만 Vercel에서 아래처럼 설정:
#   NEWRUN_MOCK=false
#   NEWRUN_ENABLED=true
NEWRUN_MOCK=true
NEWRUN_ENABLED=false
# NEWRUN_MOCK_RWR_RESULT=0

# Po-return URL 위변조 방지(선택) — 설정 시 nrpt 검증
# NEWRUN_PO_RETURN_SECRET=
# 발주 실패 시 외부 알림(선택)
# NEWRUN_ERROR_WEBHOOK_URL=
